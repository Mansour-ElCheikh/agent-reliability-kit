{
  "name": "agent-reliability-kit",
  "version": "0.1.3-dev",
  "description": "Scaffold for reliable agent work — tool-agnostic SDLC discipline kit for mixed-tool engineering teams.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r build",
    "clean": "find emitters engine -type d -name dist -prune -exec rm -rf {} +",
    "check:anatomy": "node scripts/check-anatomy.mjs",
    "check:adr": "node scripts/check-adr-numbers.mjs",
    "lint": "eslint .",
    "format": "prettier --write \"engine/**/*.ts\"",
    "format:check": "prettier --check \"engine/**/*.ts\"",
    "test:cursor": "bash emitters/cursor/test/run-test.sh",
    "test:copilot": "bash emitters/copilot/test/run-test.sh",
    "test:emitters": "pnpm test:cursor && pnpm test:copilot"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.12.7",
    "eslint": "^10.4.0",
    "js-yaml": "^4.1.0",
    "prettier": "^3.8.3",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.59.4",
    "vitest": "^1.6.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Mansour-ElCheikh/agent-reliability-kit"
  },
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.9+sha512.68046141893c66fad01c079231128e9afb89ef87e2691d69e4d40eee228988295fd4682181bae55b58418c3a253bde65a505ec7c5f9403ece5cc3cd37dcf2531"
}
