{
  "name": "@reliability-scaffold/engine",
  "version": "0.1.3-dev",
  "description": "Rules engine — audit-run + PreToolUse hook backend + ratchet. Reads governance.yaml; enforces ADR-0002 rule contract.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "scaffold-engine": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('fs').chmodSync('dist/cli.js', 0o755)\"",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "picomatch": "^4.0.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/picomatch": "^3.0.1",
    "vitest": "^1.6.0"
  }
}
