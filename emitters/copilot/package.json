{
  "name": "@reliability-kit/emit-copilot",
  "version": "0.1.3-dev",
  "description": "Copilot agent-mode emitter — reads canonical/ and writes .github/instructions/*.md + .github/copilot-instructions.md.",
  "private": true,
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "emit-copilot": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('fs').chmodSync('dist/cli.js', 0o755)\""
  },
  "dependencies": {
    "@reliability-kit/emit-lib": "workspace:*",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "nunjucks": "^3.2.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/nunjucks": "^3.2.6"
  }
}
