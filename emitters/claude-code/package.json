{
  "name": "@reliability-kit/emit-claude-code",
  "version": "0.1.3-dev",
  "description": "Claude Code emitter — reads canonical/ and writes .claude/skills/<name>/SKILL.md + .claude/agents/<name>.md + CLAUDE.md.",
  "private": true,
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "emit-claude-code": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('fs').chmodSync('dist/cli.js', 0o755)\""
  },
  "dependencies": {
    "@reliability-kit/emit-lib": "workspace:*",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "nunjucks": "^3.2.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/nunjucks": "^3.2.6"
  }
}
